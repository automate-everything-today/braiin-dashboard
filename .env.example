# -----------------------------------------------------------------------------
# Customer configuration (required)
# -----------------------------------------------------------------------------
# These values parameterise the deployment for a specific customer tenant.
# The application never hardcodes customer identity — it lives here only.

NEXT_PUBLIC_CUSTOMER_NAME="Demo Company"
NEXT_PUBLIC_CUSTOMER_EMAIL_DOMAIN="example.com"
NEXT_PUBLIC_CUSTOMER_INDUSTRY="Logistics"
NEXT_PUBLIC_CUSTOMER_INDUSTRY_DESCRIPTION="a logistics / freight forwarding company"
NEXT_PUBLIC_PIPEDRIVE_SUBDOMAIN=""

# Comma-separated list of admin email addresses allowed to sign in (required).
# Canonical name is ADMIN_EMAILS. ALLOWED_EMAILS is accepted as a legacy alias
# by the OAuth callback only — prefer ADMIN_EMAILS for all new deployments.
ADMIN_EMAILS=""

# Optional: default "from" address for system-generated emails.
# Falls back to noreply@${NEXT_PUBLIC_CUSTOMER_EMAIL_DOMAIN} if unset.
DEFAULT_SENDER_EMAIL=""
DEFAULT_SENDER_NAME=""

# Public URL of the deployed app (required in production).
# Used for OTP redirects, incident email links, etc.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Session (required)
# -----------------------------------------------------------------------------
# Secret used to sign session cookies. Must be a long random string.
# NEVER deploy without setting this — a hardcoded fallback exists only for
# local dev convenience and MUST NOT be relied on in production.
SESSION_SECRET=""

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-side service role key. Used for privileged operations from API routes.
SUPABASE_SERVICE_KEY=""

# -----------------------------------------------------------------------------
# Anthropic / Claude API (required for AI features)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=""

# -----------------------------------------------------------------------------
# Microsoft Azure / Graph API (required for email features)
# -----------------------------------------------------------------------------
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_TENANT_ID=""
AZURE_REDIRECT_URI=""

# -----------------------------------------------------------------------------
# Third-party integrations (optional)
# -----------------------------------------------------------------------------
PERPLEXITY_API_KEY=""
HUNTER_API_KEY=""
RESEND_API_KEY=""
GAMMA_API_KEY=""
PIPEDRIVE_TOKEN=""

# -----------------------------------------------------------------------------
# Cron / scheduled jobs (required if using Vercel cron)
# -----------------------------------------------------------------------------
# Shared secret that cron endpoints check against the Authorization header.
CRON_SECRET=""
